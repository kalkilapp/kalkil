    },
    {
      "id": "t24",
      "tag": "p",
      "text": "Four ad formats generate creator revenue:"
    },
    {
      "id": "t25",
      "tag": "strong",
      "text": "Skippable in-stream ads"
    },
    {
      "id": "t26",
      "tag": "li",
      "text": "— creator earns when viewer watches 30+ seconds or clicks."
    },
    {
      "id": "t27",
      "tag": "strong",
      "text": "Non-skippable ads"
    },
    {
      "id": "t28",
      "tag": "li",
      "text": "— viewer must watch; generates 20–40% higher CPM."
    },
    {
      "id": "t29",
      "tag": "strong",
      "text": "Bumper ads"
    },
    {
      "id": "t30",
      "tag": "li",
      "text": "— 6-second non-skippable; lower CPM but high frequency."
    },
    {
      "id": "t31",
      "tag": "strong",
      "text": "Display & overlay ads"
    },
    {
      "id": "t32",
      "tag": "li",
      "text": "— banner formats alongside the video player."
    },
    {
      "id": "t33",
      "tag": "p",
      "text": "Videos over 8 minutes can include mid-roll ads — typically the single biggest driver of per-video revenue."
    },
    {
      "id": "t34",
      "tag": "h2",
      "text": "Shorts Revenue"
    },
    {
      "id": "t35",
      "tag": "p",
      "text": "Shorts uses a pooled revenue model where ads between videos are shared across creators based on view share. Creators receive 45% of Shorts ad revenue. RPM ranges from $0.03 to $0.07 — best used for channel growth rather than direct income."
    },
