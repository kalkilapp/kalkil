    {
      "id": "t45",
      "tag": "button",
      "text": "Why is my Spotify payout lower than the average rate?"
    },
    {
      "id": "t46",
      "tag": "div",
      "text": "Your audience likely has a higher proportion of free-tier listeners or listeners in lower-paying markets. The average rate of $0.003–$0.005 assumes a mixed global audience of premium and free-tier subscribers."
    },
    {
      "id": "t47",
      "tag": "button",
      "text": "Does streaming more playlists increase my per-stream rate?"
    },
    {
      "id": "t48",
      "tag": "div",
      "text": "No — your rate depends on your listeners' subscription type and location, not on which playlist they found you through. Playlists increase stream volume, not rate."
    },
    {
      "id": "t49",
      "tag": "button",
      "text": "How does Spotify's rate compare to radio plays?"
    },
    {
      "id": "t50",
      "tag": "div",
      "text": "Radio performance royalties (paid through PROs) are typically lower per play than Spotify Premium streams, but radio reaches audiences who may then stream on Spotify — the two are complementary."
    },
