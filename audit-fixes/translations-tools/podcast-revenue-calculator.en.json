    {
      "id": "t33",
      "tag": "p",
      "text": "(Cost Per Mille) — brands pay per 1,000 downloads per episode. Mid-roll 60-second reads typically earn 30–50% more than pre-roll spots."
    },
    {
      "id": "t34",
      "tag": "strong",
      "text": "CPM formula: (Downloads ÷ 1,000) × CPM × Ad Slots = Revenue per episode"
    },
    {
      "id": "t35",
      "tag": "p",
      "text": "Example: 25,000 downloads × $30 CPM × 2 ads ="
    },
    {
      "id": "t36",
      "tag": "strong",
      "text": "$1,500 per episode"
    },
